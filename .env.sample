# advanced-agent — environment configuration
#
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored; never commit real secrets.

# --- Web search (Tavily) -----------------------------------------------------
# Required by the `web_search` tool. Get a key at https://tavily.com.
# Without it, web_search returns a clear error and the other tools still work.
TAVILY_API_KEY=

# --- LLM provider (OpenAI) ---------------------------------------------------
# When OPENAI_API_KEY is set, the CLI uses the OpenAI provider; otherwise it
# falls back to a placeholder model. MODEL selects the chat model.
OPENAI_API_KEY=
MODEL=gpt-5-nano
