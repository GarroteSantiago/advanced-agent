# advanced-agent — environment configuration
#
# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored; never commit real secrets.

# --- Web search (Tavily) -----------------------------------------------------
# Required by the `web_search` tool. Get a key at https://tavily.com.
# Without it, web_search returns a clear error and the other tools still work.
TAVILY_API_KEY=

# --- LLM provider (OpenAI) ---------------------------------------------------
# When OPENAI_API_KEY is set, the CLI uses the OpenAI provider; otherwise it
# falls back to a placeholder model. MODEL selects the chat model.
OPENAI_API_KEY=
MODEL=gpt-5-nano

# --- RAG (retrieval-augmented generation) ------------------------------------
# EMBED_MODEL selects the OpenAI embedding model used to build/query the index.
# RAG_INDEX_DIR is where the persisted vector store lives; the Researcher loads
# it when present (build it with `python scripts/ingest_rag.py`). CORPUS_DIR is
# only read by the ingest script.
EMBED_MODEL=text-embedding-3-small
RAG_INDEX_DIR=data/rag_index
CORPUS_DIR=data/corpus/fastapi

# --- Persistent per-project memory -------------------------------------------
# Where per-project memory JSON is stored (one file per project). Gitignored.
MEMORY_DIR=data/memory

# --- Documentation output (the Scribe) ---------------------------------------
# Folder the Scribe writes analysis results into; it is confined to this path.
DOCS_DIR=docs/analysis

# --- Observability -----------------------------------------------------------
# OBSERVABILITY=phoenix launches a local Phoenix UI (needs `uv sync --extra
# observability`); OBSERVABILITY=otel-file writes spans as JSON lines to
# OTEL_TRACE_FILE (used by scripts/analyze_repo.py). Unset = no tracing.
OBSERVABILITY=
OTEL_TRACE_FILE=otel-trace.jsonl

# --Empty--
